# ============================================================================
# AURA Frontend - Plantilla de variables de entorno
# ============================================================================
# 1) Copia este archivo como .env
# 2) Completa las variables segun tu entorno
# 3) Nunca subas secretos privados al frontend

# ----------------------------------------------------------------------------
# URL publica del frontend
# ----------------------------------------------------------------------------
# URL base de la aplicacion web (para redirecciones OTP y enlaces absolutos).
# Desarrollo: http://localhost:3000
# Produccion: https://app.aura.tudominio.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# API Backend
# ----------------------------------------------------------------------------
# URL publica del backend AURA (sin slash final recomendado).
# Desarrollo: http://localhost:8000
# Produccion: https://api.aura.tudominio.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# Supabase (cliente web)
# ----------------------------------------------------------------------------
# IMPORTANTE: en frontend solo se usa URL + ANON key (publica).
# NO usar ni exponer SUPABASE_SERVICE_KEY en frontend.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ----------------------------------------------------------------------------
# reCAPTCHA (cliente web)
# ----------------------------------------------------------------------------
# Site key publica para validar flujos de login web.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# ----------------------------------------------------------------------------
# Next.js Server Actions allowed origins (servidor)
# ----------------------------------------------------------------------------
# Lista CSV de origins permitidos para server actions.
# Debe incluir tu dominio web real en produccion.
# Ejemplo: localhost:3000,app.aura.tudominio.com
NEXT_SERVER_ACTIONS_ALLOWED_ORIGINS=localhost:3000
